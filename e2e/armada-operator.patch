diff --git a/hack/kind-config.yaml b/hack/kind-config.yaml
index a8d45c3..0a636dc 100644
--- a/hack/kind-config.yaml
+++ b/hack/kind-config.yaml
@@ -2,7 +2,26 @@ kind: Cluster
 apiVersion: kind.x-k8s.io/v1alpha4
 nodes:
 - role: control-plane
+  kubeadmConfigPatches:
+  - |
+    kind: InitConfiguration
+    nodeRegistration:
+      kubeletExtraArgs:
+        # ingress-nginx controller's kind manifest pins itself to the node
+        # labeled `ingress-ready=true` via nodeSelector. We label only the
+        # control-plane node so the controller lands here, which is also the
+        # node that gets the host 9999 -> container 80 port mapping below.
+        # Ref: https://raw.githubusercontent.com/kubernetes/ingress-nginx/controller-v1.11.3/deploy/static/provider/kind/deploy.yaml
+        node-labels: "ingress-ready=true"
   extraPortMappings:
+  # nginx ingress HTTP (host 9999 -> container 80) for OAuth Spark UI testing
+  - containerPort: 80
+    hostPort: 9999
+    protocol: TCP
+  # nginx ingress HTTPS (host 9443 -> container 443) for Spark Connect TLS
+  - containerPort: 443
+    hostPort: 9443
+    protocol: TCP
   # Lookout UI
   - containerPort: 30000
     hostPort: 30000
@@ -16,3 +35,6 @@ nodes:
